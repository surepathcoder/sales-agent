# Database (Docker Compose exposes Postgres on host port 5433)
DATABASE_URL=postgresql+asyncpg://kijani:kijani_dev_pass@localhost:5433/kijani

# Redis (Docker Compose exposes host port 6381)
REDIS_URL=redis://localhost:6381/0

# JWT
SECRET_KEY=generate-strong-key-here-change-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_MINUTES=10080
ALGORITHM=HS256

# Groq
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL_PRIMARY=llama-3.1-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant

# WhatsApp
WHATSAPP_SERVICE_URL=http://localhost:8001
WHATSAPP_SESSION_PATH=./sessions

# M-Pesa (mock for MVP)
MPESA_CONSUMER_KEY=mock
MPESA_CONSUMER_SECRET=mock
MPESA_PASSKEY=mock
MPESA_SHORTCODE=mock

# App
APP_NAME=Kijani AI
APP_ENV=development
APP_FRONTEND_URL=http://localhost:3000

# Scraping — set true for reliable dev leads without Playwright
USE_MOCK_SCRAPER=true

# Encryption (field-level encryption for PII)
ENCRYPTION_KEY=generate-32-byte-base64-key-here

# Sentry (optional)
SENTRY_DSN=

# Ollama fallback (optional)
OLLAMA_BASE_URL=http://localhost:11434
